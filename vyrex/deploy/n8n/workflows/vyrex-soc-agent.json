    "explain_finding": { "ai_tool": [ [ { "node": "VYREX SOC Agent", "type": "ai_tool", "index": 0 } ] ] },
    "investigate_incident": { "ai_tool": [ [ { "node": "VYREX SOC Agent", "type": "ai_tool", "index": 0 } ] ] },
    "dispatch_alerts": { "ai_tool": [ [ { "node": "VYREX SOC Agent", "type": "ai_tool", "index": 0 } ] ] }
