# --- SOC Central .gitignore ---

# Reference repos are STUDY-ONLY and must never enter the product tree.
reference/

# Secrets
.env
*.env
!.env.example

# Dev PKI (private keys!) — generated by scripts/gen-certs.sh
certs/

# Local data volumes / persisted state
data/
volumes/
*.db
*.sqlite3

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.mypy_cache/
.pytest_cache/
.ruff_cache/

# Go
bin/
*.exe
*.test
*.out

# Node / Next.js
node_modules/
.next/
out/
dist/
npm-debug.log*
yarn-error.log*

# ML artifacts (models are produced, not committed in Phase 0)
ml/artifacts/
*.joblib
*.pkl
*.model

# Editor / OS
.idea/
.vscode/
.DS_Store
Thumbs.db
*.swp

# Logs
*.log

# Phase B sensor test data: generated pcap + Suricata output; mirrored ET ruleset.
# Keep local.rules and the small Zeek fixtures (re-include after the *.log rule above).
tools/sensors/data/*.pcap
tools/sensors/data/out/
tools/suricata/rules/*.rules
!tools/suricata/rules/local.rules
!tools/sensors/data/zeek/conn.log
!tools/sensors/data/zeek/dns.log
