# --- SOC Central .gitignore ---

# Reference repos are STUDY-ONLY and must never enter the product tree.
reference/

# Secrets
.env
*.env
!.env.example

# Local data volumes / persisted state
data/
volumes/
*.db
*.sqlite3

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.mypy_cache/
.pytest_cache/
.ruff_cache/

# Go
bin/
*.exe
*.test
*.out

# Node / Next.js
node_modules/
.next/
out/
dist/
npm-debug.log*
yarn-error.log*

# ML artifacts (models are produced, not committed in Phase 0)
ml/artifacts/
*.joblib
*.pkl
*.model

# Editor / OS
.idea/
.vscode/
.DS_Store
Thumbs.db
*.swp

# Logs
*.log
