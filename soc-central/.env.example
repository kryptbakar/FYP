# =====================================================================
# SOC Central — environment template.
# Copy to `.env` (gitignored) and fill in real values for local dev.
# In the K3s phase these move to HashiCorp Vault. NEVER commit `.env`.
# =====================================================================

# ---- General ----
SOC_ENV=development
SOC_VERSION=0.0.0-phase0

# ---- PostgreSQL (transactional state) ----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=soc_central
POSTGRES_USER=soc
POSTGRES_PASSWORD=change_me_postgres

# ---- TimescaleDB (time-series telemetry) ----
TIMESCALE_HOST=timescaledb
# Host-published port. 5433 to avoid clashing with PostgreSQL's 5432 on the host.
# (Internal service-to-service traffic still uses 5432 over the compose network.)
TIMESCALE_PORT=5433
TIMESCALE_DB=soc_telemetry
TIMESCALE_USER=soc
TIMESCALE_PASSWORD=change_me_timescale

# ---- OpenSearch (full-text / log search) ----
OPENSEARCH_HOST=opensearch
OPENSEARCH_PORT=9200
OPENSEARCH_SCHEME=http
# OpenSearch 2.12+ requires a strong initial admin password.
OPENSEARCH_INITIAL_ADMIN_PASSWORD=Change_me_OpenSearch_1!

# ---- NATS JetStream (message broker) ----
NATS_HOST=nats
NATS_PORT=4222
NATS_MONITOR_PORT=8222
NATS_URL=nats://nats:4222

# ---- API service ----
API_HOST=0.0.0.0
API_PORT=8000
API_LOG_LEVEL=info

# ---- Grafana (presentation) ----
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_grafana

# ---- Ingestion backbone (Phase 1) ----
# ingest-edge mTLS telemetry listener (host-published port).
INGEST_PORT=8443
# Shared bearer token agents present alongside their mTLS client cert.
INGEST_AGENT_TOKEN=change_me_agent_token
# Set >0 (ms) to artificially slow workers and demonstrate broker back-pressure.
WORKER_SLOW_MS=0

# ---- Feed sync (the ONLY internet-facing job; used from Phase 3) ----
# Request a free key at https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=
EPSS_CSV_URL=https://epss.cyentia.com/epss_scores-current.csv.gz
KEV_JSON_URL=https://www.cisa.gov/sites/default/files/feeds/known_exploited_vulnerabilities.json
