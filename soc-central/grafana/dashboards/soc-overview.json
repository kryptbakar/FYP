{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "schemaVersion": 39,
  "tags": ["soc-central", "overview"],
  "title": "VYREX — Security Overview",
  "uid": "soc-overview",
  "time": { "from": "now-7d", "to": "now" },
  "timezone": "",
  "refresh": "30s",
  "templating": { "list": [] },
  "panels": [
    {
      "type": "stat", "title": "Open Findings", "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "postgres", "uid": "soc-postgres" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "#38bdf8" }, "unit": "short" }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "auto", "textMode": "value", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [ { "refId": "A", "format": "table", "rawQuery": true, "rawSql": "SELECT count(*) AS value FROM findings" } ]
    },
    {
      "type": "stat", "title": "KEV-flagged", "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "postgres", "uid": "soc-postgres" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "#fb3b6b" }, "unit": "short" }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "none", "textMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [ { "refId": "A", "format": "table", "rawQuery": true, "rawSql": "SELECT count(*) AS value FROM findings WHERE kev" } ]
    },
    {
      "type": "stat", "title": "Critical + High", "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "postgres", "uid": "soc-postgres" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "#fb923c" }, "unit": "short" }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "none", "textMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [ { "refId": "A", "format": "table", "rawQuery": true, "rawSql": "SELECT count(*) AS value FROM findings WHERE upper(severity) IN ('CRITICAL','HIGH')" } ]
    },
    {
      "type": "stat", "title": "Avg Composite Risk", "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "postgres", "uid": "soc-postgres" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "unit": "short", "min": 0, "max": 100,
        "thresholds": { "mode": "absolute", "steps": [ { "color": "#38bdf8", "value": null }, { "color": "#fbbf24", "value": 40 }, { "color": "#fb923c", "value": 60 }, { "color": "#fb3b6b", "value": 80 } ] } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [ { "refId": "A", "format": "table", "rawQuery": true, "rawSql": "SELECT round(avg(risk_score),1) AS value FROM findings WHERE risk_score IS NOT NULL" } ]
    },

    {
      "type": "piechart", "title": "Findings by Severity", "gridPos": { "h": 8, "w": 8, "x": 0, "y": 4 },
      "datasource": { "type": "postgres", "uid": "soc-postgres" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } }, "overrides": [
        { "matcher": { "id": "byName", "options": "CRITICAL" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "#fb3b6b" } } ] },
        { "matcher": { "id": "byName", "options": "HIGH" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "#fb923c" } } ] },
        { "matcher": { "id": "byName", "options": "MEDIUM" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "#fbbf24" } } ] },
        { "matcher": { "id": "byName", "options": "LOW" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "#38bdf8" } } ] } ] },
      "options": { "pieType": "donut", "legend": { "displayMode": "list", "placement": "right", "values": ["value"] }, "reduceOptions": { "calcs": ["lastNotNull"], "values": true } },
      "targets": [ { "refId": "A", "format": "table", "rawQuery": true, "rawSql": "SELECT upper(severity) AS metric, count(*) AS value FROM findings GROUP BY upper(severity) ORDER BY 2 DESC" } ]
    },
    {
      "type": "piechart", "title": "Detection Fusion — by Tool", "gridPos": { "h": 8, "w": 8, "x": 8, "y": 4 },
      "datasource": { "type": "postgres", "uid": "soc-postgres" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } }, "overrides": [] },
      "options": { "pieType": "pie", "legend": { "displayMode": "list", "placement": "right", "values": ["value"] }, "reduceOptions": { "calcs": ["lastNotNull"], "values": true } },
      "targets": [ { "refId": "A", "format": "table", "rawQuery": true, "rawSql": "SELECT source_tool AS metric, count(*) AS value FROM findings GROUP BY source_tool ORDER BY 2 DESC" } ]
    },
    {
      "type": "bargauge", "title": "Open Findings by Asset", "gridPos": { "h": 8, "w": 8, "x": 16, "y": 4 },
      "datasource": { "type": "postgres", "uid": "soc-postgres" },
      "fieldConfig": { "defaults": { "color": { "mode": "continuous-BlPu" }, "unit": "short" }, "overrides": [] },
      "options": { "displayMode": "gradient", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"], "values": true } },
      "targets": [ { "refId": "A", "format": "table", "rawQuery": true, "rawSql": "SELECT asset_id AS metric, count(*) AS value FROM findings GROUP BY asset_id ORDER BY 2 DESC LIMIT 10" } ]
    },

    {
      "type": "table", "title": "Risk-Prioritized Queue (top 15)", "gridPos": { "h": 10, "w": 24, "x": 0, "y": 12 },
      "datasource": { "type": "postgres", "uid": "soc-postgres" },
      "fieldConfig": { "defaults": { "custom": { "align": "left", "filterable": true } }, "overrides": [
        { "matcher": { "id": "byName", "options": "risk" }, "properties": [
          { "id": "custom.cellOptions", "value": { "type": "gauge", "mode": "gradient" } },
          { "id": "max", "value": 100 }, { "id": "min", "value": 0 },
          { "id": "color", "value": { "mode": "continuous-RdYlGr" } } ] },
        { "matcher": { "id": "byName", "options": "kev" }, "properties": [ { "id": "custom.cellOptions", "value": { "type": "color-text" } } ] } ] },
      "options": { "showHeader": true, "cellHeight": "sm", "sortBy": [ { "displayName": "risk", "desc": true } ] },
      "targets": [ { "refId": "A", "format": "table", "rawQuery": true, "rawSql": "SELECT risk_rank AS \"#\", title, asset_id AS asset, source_tool AS tool, severity, cve_id AS cve, kev, round(risk_score,1) AS risk, round(ml_risk_score,1) AS ml, attack FROM findings WHERE risk_score IS NOT NULL ORDER BY risk_score DESC LIMIT 15" } ]
    },

    {
      "type": "timeseries", "title": "Telemetry Ingest Volume", "gridPos": { "h": 7, "w": 24, "x": 0, "y": 22 },
      "datasource": { "type": "postgres", "uid": "soc-timescale" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "#38bdf8" }, "custom": { "drawStyle": "bars", "fillOpacity": 30, "lineWidth": 1 }, "unit": "short" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [ { "refId": "A", "format": "time_series", "rawQuery": true, "rawSql": "SELECT $__timeGroupAlias(ingested_at, '1h'), count(*) AS events FROM telemetry_raw WHERE $__timeFilter(ingested_at) GROUP BY 1 ORDER BY 1" } ]
    }
  ]
}
