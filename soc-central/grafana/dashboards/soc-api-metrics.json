{
  "uid": "soc-api-metrics",
  "title": "VYREX — API metrics",
  "tags": ["soc-central", "observability"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Request rate (req/s by route)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "soc-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (path) (rate(soc_http_requests_total[5m]))",
          "legendFormat": "{{path}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Error rate (5xx, req/s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "soc-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(soc_http_requests_total{status=~\"5..\"}[5m]))",
          "legendFormat": "5xx"
        }
      ]
    },
    {
      "id": 3,
      "title": "p95 latency (s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "soc-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, path) (rate(soc_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 {{path}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Total requests (1h)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "soc-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(soc_http_requests_total[1h]))",
          "legendFormat": "requests"
        }
      ]
    }
  ]
}
