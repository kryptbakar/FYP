    { "parameters": { "method": "POST", "url": "={{ $env.VYREX_API }}/reports", "sendBody": true, "specifyBody": "json", "jsonBody": "={ \"type\": \"posture\" }", "options": {} }, "id": "n11", "name": "Posture report", "type": "n8n-nodes-base.httpRequest", "typeVersion": 4.2, "position": [ -420, 400 ] },
