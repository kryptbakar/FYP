    { "parameters": { "url": "={{ $env.VYREX_API }}/incidents?limit=200", "options": {} }, "id": "n20", "name": "Get incidents", "type": "n8n-nodes-base.httpRequest", "typeVersion": 4.2, "position": [ -420, 940 ] },
    { "parameters": { "jsCode": "const b = $input.all().filter(i => i.json && i.json.sla_breached === true);\nreturn [{ json: { breached: b.length } }];" }, "id": "n21", "name": "Count breached", "type": "n8n-nodes-base.code", "typeVersion": 2, "position": [ -200, 940 ] },
    { "parameters": { "conditions": { "options": { "version": 2 }, "combinator": "and", "conditions": [ { "leftValue": "={{ $json.breached }}", "rightValue": 0, "operator": { "type": "number", "operation": "gt" } } ] }, "options": {} }, "id": "n22", "name": "Any breached?", "type": "n8n-nodes-base.if", "typeVersion": 2, "position": [ 20, 940 ] },
