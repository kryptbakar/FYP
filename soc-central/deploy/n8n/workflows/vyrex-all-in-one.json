    { "parameters": { "fromEmail": "vyrex@soc.local", "toEmail": "soc-team@soc.local", "subject": "=VYREX alert — {{ $json.body.subject || 'notification' }}", "emailFormat": "text", "text": "=A VYREX alert was routed to n8n.\n\nSeverity: {{ $json.body.severity }}\nSubject:  {{ $json.body.subject }}\nBody:     {{ $json.body.body }}\n\n(Air-gapped demo: lands in Mailpit at http://localhost:8025)", "options": {} }, "id": "n17", "name": "Email the SOC team", "type": "n8n-nodes-base.emailSend", "typeVersion": 2.1, "position": [ -420, 760 ], "credentials": { "smtp": { "id": "vyrexMailpitSmtp", "name": "Mailpit SMTP" } }, "onError": "continueRegularOutput" },
