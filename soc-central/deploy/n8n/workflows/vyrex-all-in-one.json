    { "parameters": { "conditions": { "options": { "caseSensitive": false, "version": 2 }, "combinator": "or", "conditions": [ { "leftValue": "={{ $json.body.finding.severity }}", "rightValue": "CRITICAL", "operator": { "type": "string", "operation": "equals" } }, { "leftValue": "={{ $json.body.finding.severity }}", "rightValue": "HIGH", "operator": { "type": "string", "operation": "equals" } } ] }, "options": {} }, "id": "n06", "name": "Severity high/critical?", "type": "n8n-nodes-base.if", "typeVersion": 2, "position": [ -420, 200 ] },
