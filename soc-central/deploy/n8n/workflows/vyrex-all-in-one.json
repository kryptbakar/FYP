    { "parameters": { "jsCode": "const hot = $input.all().filter(i => i.json && i.json.threat_intel && Number(i.json.risk_score) >= 60);\nreturn [{ json: { count: hot.length } }];" }, "id": "n27", "name": "Filter live IOCs", "type": "n8n-nodes-base.code", "typeVersion": 2, "position": [ -200, 1160 ] },
