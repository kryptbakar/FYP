    { "parameters": { "url": "={{ $env.VYREX_API }}/risk/ranking?limit=50", "options": {} }, "id": "n02", "name": "Ranking (triage)", "type": "n8n-nodes-base.httpRequest", "typeVersion": 4.2, "position": [ -420, 0 ] },
    { "parameters": { "method": "POST", "url": "={{ $env.VYREX_API }}/incidents/correlate", "sendBody": true, "specifyBody": "json", "jsonBody": "={ \"min_score\": 70, \"window_hours\": 24 }", "options": {} }, "id": "n03", "name": "Correlate (triage)", "type": "n8n-nodes-base.httpRequest", "typeVersion": 4.2, "position": [ -200, 0 ] },
    { "parameters": { "method": "POST", "url": "={{ $env.VYREX_API }}/alerts/dispatch", "sendBody": true, "specifyBody": "json", "jsonBody": "={}", "options": {} }, "id": "n04", "name": "Dispatch (triage)", "type": "n8n-nodes-base.httpRequest", "typeVersion": 4.2, "position": [ 20, 0 ] },

